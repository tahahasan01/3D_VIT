# Server configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Optional: use GPU/neural garment model (runs slow on CPU but can generate properly)
# USE_NEURAL_GARMENT=1
# NEURAL_GARMENT_SCRIPT=C:\path\to\server\scripts\run_neural_garment.py
# NEURAL_GARMENT_TIMEOUT=300
# CHATGARMENT_ROOT=C:\path\to\chatgarment   # required for ChatGarment pipeline
# CHATGARMENT_PYTHON=C:\path\to\conda\envs\chatgarment\python.exe   # optional; use ChatGarment conda env for eval/sim

# Optional: drape garment on SMPL body via ISP (requires ISP repo + --garment_mesh patch)
# USE_ISP_DRAPING=1
# ISP_ROOT=C:\path\to\ISP
# ISP_PYTHON=C:\path\to\conda\envs\isp\python.exe   # optional; use ISP conda env
# ISP_DRAPING_TIMEOUT=120

# Optional: FabricDiffusion for texture rectification (flat, tileable base colour)
# USE_FABRIC_DIFFUSION=1
# FABRIC_DIFFUSION_ROOT=C:\path\to\FabricDiffusion
# FABRIC_DIFFUSION_PYTHON=C:\path\to\conda\envs\fabdiff\python.exe
# FABRIC_DIFFUSION_TIMEOUT=120
